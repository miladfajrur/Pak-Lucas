rules_version = '2';

// ===============================================================
// Assumed Data Model
// ===============================================================
// Collection: portfolio
// Document ID: data
// Fields:
//   - personalInfo: string (JSON)
//   - publications: string (JSON)
//   - teachingMaterials: string (JSON)
//   - researchProjects: string (JSON)
//   - updatedAt: string
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
       return request.auth != null;
    }

    function isAdmin() {
      // Izinkan hanya email milik Anda yang punya hak akses penuh
      return isAuthenticated() && 
             request.auth.token.email == "fajrurrr.19@gmail.com" && 
             request.auth.token.email_verified == true;
    }

    match /portfolio/{docId} {
      // Allow public read since this is a public portfolio website
      allow read: if docId == 'data';
      
      // Allow write if authenticated with the specific admin email
      allow write: if isAdmin() && docId == 'data';
    }
  }
}
